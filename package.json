    "dev": "nodemon server.js",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "gh-pages": "^6.3.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "mongoose": "^9.4.1",
    "nodemailer": "^8.0.5"
  },

  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
