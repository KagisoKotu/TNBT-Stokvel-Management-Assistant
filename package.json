{
  
  "homepage": "https://gomolemorampa.github.io/TNBT-Stokvel-Management-Assistant",
  "scripts": {
    "start": "node server.js",
    "build": "cd frontend && npm run build",
    "predeploy": "cd frontend && npm run build",
